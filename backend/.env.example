DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/run_event_db2
PORT=3000

# Optional: Maps / AI moderation
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_LLM_MODERATION_ENABLED=true
OPENAI_LLM_MODERATION_MODEL=gpt-5-mini
OPENAI_LLM_MODERATION_TIMEOUT_MS=8000

# Optional: Stripe (server-side only). Leave blank to disable Stripe routes.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: Airwallex (demo/sandbox)
AIRWALLEX_ENV=demo
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_WEBHOOK_SECRET=
AIRWALLEX_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_ALIPAY_ENABLED=false
AIRWALLEX_RETURN_URL=http://localhost:3000/payment/airwallex-return

# Optional: Antom / Alipay
ALIPAY_PROVIDER=airwallex
ANTOM_BASE_URL=https://open-sea-global.alipay.com
ANTOM_CLIENT_ID=
ANTOM_PRIVATE_KEY=
ANTOM_PUBLIC_KEY=
ANTOM_KEY_VERSION=1
ANTOM_ALIPAY_ENABLED=false
ALIPAY_NOTIFY_URL=

# App/Checkout URLs
APP_BASE_URL=http://localhost:3000
STRIPE_SUCCESS_URL=http://localhost:3000/paid-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/paid-cancel
